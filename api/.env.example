# Supabase — get these from your project dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# JWT secret — must match Supabase JWT secret (Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# CORS — your Expo app origin in production
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081
