# Copy this file to .env and fill in your values.
# .env is gitignored — set the same vars in Railway's "Variables" dashboard.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # only if you need admin ops

# Server
PORT=3000
NODE_ENV=development
